\disable@package@load{auxhook}{}
\RequirePackage{hyperref}
\hypersetup{%
    colorlinks,%
    linkcolor={black},%
    citecolor={black},%
    urlcolor={black}%
}
\RequirePackage[noabbrev]{cleveref}
\numberwithin{equation}{section}
%%%%%%%%%%%%%%%%%% REFERENCING SUB-EQUATIONS %%%%%%%%%%%%%%%%%%%
\RequirePackage{xstring}
\DeclareDocumentCommand{\subeqref}{m o}{%
    \edef\c{\detokenize{#1}}%
    \edef\lbracetoken{\string{}%
    \edef\rbracetoken{\string}}%
    \StrBetween{\c}{\lbracetoken}{\rbracetoken}[\temp]%
    (\hyperref[\temp]{#1#2})%
}
